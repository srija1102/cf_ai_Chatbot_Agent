/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my-agent",
  "main": "src/server.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*", "/api/*"]
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "CodeReviewAgentV2",
        "name": "CodeReviewAgent"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": ["ChatAgent"],
      "tag": "v1"
    },
    {
      "renamed_classes": [{ "from": "ChatAgent", "to": "CodeReviewAgent" }],
      "tag": "v2"
    },
    {
      "new_sqlite_classes": ["CodeReviewAgentV2"],
      "tag": "v3"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "code-review-sessions",
      "database_id": "88c43951-c093-4bd5-be8c-71e4ebfab1b6"
    }
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "CF_ACCOUNT_ID": "e5bcf0e84e2def1385a56e84780573fc"
  }
  /**
   * Service Bindings (communicate between multiple Workers)
   * https://developers.cloudflare.com/workers/wrangler/configuration/#service-bindings
   */
  // "services": [  {   "binding": "MY_SERVICE",   "service": "my-service"  } ]
}
